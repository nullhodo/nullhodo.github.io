---
import '../styles/global.css';
import { Image } from 'astro:assets';
import goldenRatioImg from '../assets/artworks/golden-ratio-animation.jpg';
import badAppleImg from '../assets/artworks/bad-apple-console.jpg';
import coinTossImg from '../assets/artworks/coin-toss.png';

// Dynamically import all genart-misc images
const miscImages = import.meta.glob<{ default: ImageMetadata }>('../assets/artworks/genart-misc-*.{png,jpg,jpeg}', { eager: true });
const miscImagePaths = Object.values(miscImages).map(img => img.default);
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Artworks | nullhodo</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@300;400;500;700;900&display=swap"
            rel="stylesheet"
        />
        <style>
            .artwork-list {
                list-style: none;
                padding: 0;
            }
            .artwork-item {
                margin-bottom: 3rem;
            }
            .artwork-image {
                width: 100%;
                max-width: 400px;
                height: auto;
                aspect-ratio: 4 / 3;
                object-fit: cover;
                object-position: center;
                display: block;
                margin-top: 0.5rem;
                margin-bottom: 0.5rem;
                border: 1px solid #eee;
            }
            .navigation {
                margin-bottom: 2rem;
            }
            .misc-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
                gap: 1rem;
                padding: 0;
                list-style: none;
                margin-top: 1rem;
                margin-bottom: 3rem;
            }
            .misc-item img {
                width: 100%;
                height: auto;
                aspect-ratio: 4 / 3;
                object-fit: cover;
                object-position: center;
                border: 1px solid #eee;
                display: block;
            }
        </style>
    </head>
    <body>
        <h2>Artworks</h2>
        <div class="navigation">
            <a href="/">Back to Home</a>
            <span> | </span>
            <a
                href="https://x.com/search?q=from%3A%40nullhodo%20%22%23%E3%81%A4%E3%81%B6%E3%82%84%E3%81%8DProcessing%22%20OR%20%22%23%E3%82%A2%E3%83%B3%E3%83%93%E3%82%B0%E3%83%A9%E3%83%A0%22%20OR%20%22%23p5js%22%20OR%20%22%23generativeart%22%20OR%20%22%23creativecoding%22"
                target="_blank"
                rel="noopener noreferrer"
                >Search all artworks on X</a
            >
        </div>

        <span>This page is currently under construction...</span>

        <ul class="artwork-list">
            <li class="artwork-item">
                <h3>Golden Ratio Animation</h3>
                <Image src={goldenRatioImg} alt="Golden Ratio Animation" width={800} height={600} fit="cover" format="jpeg" class="artwork-image" />
                <p>A looping animation based on the golden spiral and golden rectangle, along with its generator. Created with p5.js.</p>
                <a href="https://nullhodo.github.io/golden-ratio-animation/" target="_blank" rel="noopener noreferrer">Play</a>
                <span> | </span>
                <a href="https://github.com/nullhodo/golden-ratio-animation" target="_blank" rel="noopener noreferrer">GitHub</a>
            </li>
            <li class="artwork-item">
                <h3>Bad Apple on Console</h3>
                <Image src={badAppleImg} alt="Bad Apple on Console" width={800} height={600} fit="cover" format="jpeg" class="artwork-image" />
                <p>A Bad Apple!! animation playable in the browser console.</p>
                <a href="https://www.youtube.com/watch?v=rGLftsGAEf0" target="_blank" rel="noopener noreferrer">Watch on YouTube</a>
                <span> | </span>
                <a href="https://github.com/nullhodo/bad-apple-console" target="_blank" rel="noopener noreferrer">GitHub</a>
            </li>
            <li class="artwork-item">
                <h3>Coin Toss</h3>
                <Image src={coinTossImg} alt="Coin Toss" width={800} height={600} fit="cover" format="jpeg" class="artwork-image" />
                <p>A coin toss simulation. Created with Three.js.</p>
                <a href="https://nullhodo.github.io/coin-toss/" target="_blank" rel="noopener noreferrer">Play</a>
                <span> | </span>
                <a href="https://github.com/nullhodo/coin-toss" target="_blank" rel="noopener noreferrer">GitHub</a>
            </li>
        </ul>

        <h2>Other Sketches</h2>
        <ul class="misc-grid">
            {miscImagePaths.map((img, index) => (
                <li class="misc-item">
                    <Image
                        src={img}
                        alt={`Generative Art Sketch ${index + 1}`}
                        width={400}
                        height={300}
                        fit="cover"
                        format="jpeg"
                    />
                </li>
            ))}
        </ul>

        <div style="margin-top: 3rem;">
            <a href="/">Back to Home</a>
        </div>
    </body>
</html>
