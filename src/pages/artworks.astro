---
import '../styles/global.css';
import { Image } from 'astro:assets';
import goldenRatioImg from '../assets/artworks/golden-ratio-animation.jpg';
import badAppleImg from '../assets/artworks/bad-apple-console.jpg';
import coinTossImg from '../assets/artworks/coin-toss.png';

// Dynamically import all genart-misc images
const miscImages = import.meta.glob<{ default: ImageMetadata }>('../assets/artworks/genart-misc-*.{png,jpg,jpeg}', { eager: true });

// Sort images numerically based on the number in the filename
const miscImagePaths = Object.entries(miscImages)
    .map(([path, mod]) => {
        const match = path.match(/genart-misc-(\d+)\.(png|jpg|jpeg)$/);
        const num = match ? parseInt(match[1], 10) : 0;
        return { num, img: mod.default };
    })
    .sort((a, b) => a.num - b.num)
    .map(item => item.img);
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Artworks | nullhodo</title>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Zen+Maru+Gothic:wght@300;400;500;700;900&display=swap"
            rel="stylesheet"
        />
        <style>
            .artwork-list {
                list-style: none;
                padding: 0;
            }
            .artwork-item {
                margin-bottom: 3rem;
            }
            .artwork-image {
                width: 100%;
                max-width: 400px;
                height: auto;
                aspect-ratio: 4 / 3;
                object-fit: cover;
                object-position: center;
                display: block;
                margin-top: 0.5rem;
                margin-bottom: 0.5rem;
                border: 1px solid #eee;
            }
            .text-block {
                display: inline-block;
            }
            .navigation {
                margin-bottom: 2rem;
            }
            .misc-grid {
                display: grid;
                grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
                gap: 1rem;
                padding: 0;
                list-style: none;
                margin-top: 1rem;
                margin-bottom: 3rem;
            }
            .misc-item img {
                width: 100%;
                height: auto;
                aspect-ratio: 4 / 3;
                object-fit: cover;
                object-position: center;
                border: 1px solid #eee;
                display: block;
                cursor: pointer;
                transition: transform 0.2s, opacity 0.2s;
                user-select: none;
                -webkit-user-select: none;
                -webkit-user-drag: none;
            }
            .misc-item img:hover {
                box-shadow: 0 0 0 2px #444;
            }
            .modal {
                border: none;
                padding: 0;
                background: transparent;
                max-width: 90vw;
                max-height: 90vh;
                outline: none;
                overflow: visible;
                position: relative;
            }
            .modal::backdrop {
                background-color: rgba(0, 0, 0, 0.85);
                backdrop-filter: blur(4px);
            }
            .modal img {
                max-width: 100%;
                max-height: 90vh;
                display: block;
                margin: 0 auto;
                border-radius: 4px;
                box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
                user-select: none;
                -webkit-user-select: none;
                -webkit-user-drag: none;
            }
            .nav-button {
                position: absolute;
                top: 50%;
                transform: translateY(-50%);
                background: rgba(255, 255, 255, 0.25);
                color: white;
                border: none;
                width: 50px;
                height: 50px;
                border-radius: 50%;
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                transition: background 0.2s, transform 0.2s;
                z-index: 10;
                user-select: none;
                padding: 0;
            }
            .nav-button svg {
                width: 24px;
                height: 24px;
                display: block;
            }
            .nav-button:hover {
                background: rgba(255, 255, 255, 0.4);
                transform: translateY(-50%) scale(1.1);
            }
            .prev-button {
                left: -70px;
            }
            .next-button {
                right: -70px;
            }

            @media (max-width: 768px) {
                .prev-button {
                    left: 10px;
                }
                .next-button {
                    right: 10px;
                }
                .nav-button {
                    background: rgba(0, 0, 0, 0.5);
                    width: 40px;
                    height: 40px;
                }
                .nav-button svg {
                    width: 20px;
                    height: 20px;
                }
                .nav-button:hover {
                    background: rgba(0, 0, 0, 0.7);
                    transform: translateY(-50%) scale(1);
                }
            }
        </style>
    </head>
    <body>
        <h1>Artworks</h1>
        <div class="navigation">
            <a href="/">Back to Home</a>
            <span> | </span>
            <a
                href="https://x.com/search?q=from%3A%40nullhodo%20%22%23%E3%81%A4%E3%81%B6%E3%82%84%E3%81%8DProcessing%22%20OR%20%22%23%E3%82%A2%E3%83%B3%E3%83%93%E3%82%B0%E3%83%A9%E3%83%A0%22%20OR%20%22%23p5js%22%20OR%20%22%23generativeart%22%20OR%20%22%23creativecoding%22"
                target="_blank"
                rel="noopener noreferrer"
                >Search all artworks on X</a
            >
        </div>

        <span>This page is currently under construction...</span>

        <ul class="artwork-list">
            <li class="artwork-item">
                <h2>Golden Ratio Animation</h2>
                <Image src={goldenRatioImg} alt="Golden Ratio Animation" width={800} height={600} fit="cover" format="webp" quality={85} class="artwork-image" />
                <p><span class="text-block">A looping animation based on the golden spiral and golden rectangle, along with its generator.</span> <span class="text-block">Created with p5.js.</span></p>
                <a href="https://nullhodo.github.io/golden-ratio-animation/" target="_blank" rel="noopener noreferrer">Play</a>
                <span> | </span>
                <a href="https://github.com/nullhodo/golden-ratio-animation" target="_blank" rel="noopener noreferrer">GitHub</a>
            </li>
            <li class="artwork-item">
                <h2>Bad Apple on Console</h2>
                <Image src={badAppleImg} alt="Bad Apple on Console" width={800} height={600} fit="cover" format="webp" quality={85} class="artwork-image" />
                <p><span class="text-block">A Bad Apple!! animation playable</span> <span class="text-block">in the browser console.</span></p>
                <a href="https://www.youtube.com/watch?v=rGLftsGAEf0" target="_blank" rel="noopener noreferrer">Watch on YouTube</a>
                <span> | </span>
                <a href="https://github.com/nullhodo/bad-apple-console" target="_blank" rel="noopener noreferrer">GitHub</a>
            </li>
            <li class="artwork-item">
                <h2>Coin Toss</h2>
                <Image src={coinTossImg} alt="Coin Toss" width={800} height={600} fit="cover" format="webp" quality={85} class="artwork-image" />
                <p><span class="text-block">A coin toss simulation.</span> <span class="text-block">Created with Three.js.</span></p>
                <a href="https://nullhodo.github.io/coin-toss/" target="_blank" rel="noopener noreferrer">Play</a>
                <span> | </span>
                <a href="https://github.com/nullhodo/coin-toss" target="_blank" rel="noopener noreferrer">GitHub</a>
            </li>
        </ul>

        <h2>Other Sketches</h2>
        <ul class="misc-grid">
            {miscImagePaths.map((img, index) => (
                <li class="misc-item">
                    <Image
                        src={img}
                        alt={`Generative Art Sketch ${index + 1}`}
                        width={800}
                        height={600}
                        fit="cover"
                        format="webp"
                        quality={85}
                    />
                </li>
            ))}
        </ul>

        <dialog id="image-modal" class="modal">
            <button id="prev-modal" class="nav-button prev-button" aria-label="Previous image">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </button>
            <img id="modal-img" src="" alt="Zoomed Sketch" />
            <button id="next-modal" class="nav-button next-button" aria-label="Next image">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>
        </dialog>

        <div style="margin-top: 3rem; margin-bottom: 5rem;">
            <a href="/">Back to Home</a>
        </div>

        <script>
            const modal = document.getElementById('image-modal') as HTMLDialogElement;
            const modalImg = document.getElementById('modal-img') as HTMLImageElement;
            const prevBtn = document.getElementById('prev-modal');
            const nextBtn = document.getElementById('next-modal');
            const images = document.querySelectorAll('.misc-item img');
            let currentIndex = 0;

            const updateModalImage = (index: number) => {
                const img = images[index];
                if (img && modalImg) {
                    const src = img.getAttribute('src');
                    const alt = img.getAttribute('alt');
                    if (src) {
                        modalImg.src = src;
                        modalImg.alt = alt || 'Zoomed Sketch';
                        currentIndex = index;
                    }
                }
            };

            images.forEach((img, index) => {
                img.addEventListener('click', () => {
                    updateModalImage(index);
                    modal?.showModal();
                });
            });

            const showPrev = () => {
                const nextIdx = (currentIndex - 1 + images.length) % images.length;
                updateModalImage(nextIdx);
            };

            const showNext = () => {
                const nextIdx = (currentIndex + 1) % images.length;
                updateModalImage(nextIdx);
            };

            prevBtn?.addEventListener('click', (e) => {
                e.stopPropagation(); // Avoid triggering backdrop close
                showPrev();
            });

            nextBtn?.addEventListener('click', (e) => {
                e.stopPropagation(); // Avoid triggering backdrop close
                showNext();
            });

            modal?.addEventListener('click', (e) => {
                if (e.target === modal) {
                    modal.close();
                }
            });

            document.addEventListener('keydown', (e) => {
                if (modal?.open) {
                    if (e.key === 'ArrowLeft') {
                        showPrev();
                    } else if (e.key === 'ArrowRight') {
                        showNext();
                    }
                }
            });
        </script>
    </body>
</html>
